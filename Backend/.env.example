# Copy to .env and adjust. Loaded by django-environ.

# --- Core ---
SECRET_KEY=dev-insecure-change-me-please-0123456789
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (SQLite by default; WAL mode set in code) ---
DATABASE_URL=sqlite:///db.sqlite3

# --- CORS / frontend origin (credentials enabled for httpOnly refresh cookie) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- JWT cookie ---
# In production set JWT_COOKIE_SECURE=True and JWT_COOKIE_SAMESITE=None (cross-site over HTTPS).
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Email (console backend in dev prints to terminal) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=clinic@example.com
# For real SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# --- Optional SMS / WhatsApp (Twilio) ---
# Get Account SID from console.twilio.com main page.
# Recommended: create an API Key (console → Account → API keys & tokens) instead of
# using the master Auth Token — API keys can be revoked without resetting everything.
#
# Option A — API Key auth (preferred):
#   TWILIO_API_KEY   = SK...  (the key SID)
#   TWILIO_AUTH_TOKEN = ...   (the key SECRET — not the master token)
# Option B — Auth Token:
#   leave TWILIO_API_KEY blank; set TWILIO_AUTH_TOKEN to the master token
SMS_ENABLED=False
WHATSAPP_ENABLED=False
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx          # Twilio SMS number (E.164)
# WhatsApp sender: must be registered in Twilio → Messaging → WhatsApp senders
# For testing use the Twilio sandbox: +14155238886
TWILIO_WHATSAPP_FROM=+14155238886

# --- Scheduling / booking knobs ---
SLOT_HORIZON_DAYS=60
CANCELLATION_WINDOW_HOURS=4
REMINDER_24H_WINDOW_MINUTES=30
REMINDER_1H_WINDOW_MINUTES=15
WAITLIST_HOLD_HOURS=24

# --- Clinic branding (prescription PDFs / reports) ---
CLINIC_NAME=Sunrise Family Clinic

# --- AI Scribe (apps/ai_scribe): record a visit -> transcript -> reviewable draft ---
AI_SCRIBE_ENABLED=True
# Speech-to-text (faster-whisper, runs locally/offline). large-v3 is the most
# accurate for Egyptian Arabic but heavy on CPU — the FIRST run downloads ~3 GB
# of weights, and transcription on a CPU-only machine can take several minutes
# per session. If that's too slow, drop to "medium" or "small".
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cpu              # "cuda" if you have an NVIDIA GPU
WHISPER_COMPUTE_TYPE=int8       # int8 = CPU-friendly; use float16 on GPU
WHISPER_DEFAULT_LANGUAGE=ar     # auto-detect if left blank
AI_SCRIBE_MAX_AUDIO_MB=80
# Structured extraction (Google Gemini — FREE key, no credit card):
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
